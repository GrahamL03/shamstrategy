{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for ShamStrategy Node E",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    {
      "identifier": "sql:allow-execute",
      "allow": [{ "path": "sqlite:shamstrategy.db" }]
    },
    {
      "identifier": "sql:allow-load",
      "allow": [{ "path": "sqlite:shamstrategy.db" }]
    }
  ]
}